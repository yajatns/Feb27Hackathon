# backoffice.ai - Environment Variables
# Copy to .env and fill in values

# OpenRouter (LLM)
OPENROUTER_API_KEY=sk-or-v1-...

# Senso (Policy Ground Truth)
SENSO_API_KEY=tgr_...

# Reka Vision (Document + Video Intelligence)
REKA_API_KEY=...

# Yutori (Web Browsing Automation)
YUTORI_API_KEY=yt_...

# Tavily (Market Research)
TAVILY_API_KEY=tvly-dev-...

# Render
RENDER_API_KEY=rnd_...

# Notion (via Airbyte)
NOTION_TOKEN=ntn_...

# Airbyte Agent Engine
AIRBYTE_CLIENT_ID=
AIRBYTE_CLIENT_SECRET=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=backoffice2026

# Postgres (Render provides DATABASE_URL)
DATABASE_URL=postgresql://...

# App
APP_ENV=production
APP_PORT=8000
